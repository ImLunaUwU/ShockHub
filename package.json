{
  "name": "openshock-spicer",
  "version": "0.1.0",
  "description": "OpenShock desktop controller (API v2 only)",
  "main": "main.js",
  "author": "Luna",
  "license": "MIT",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make-debug": "cross-env DEBUG=electron-forge:* electron-forge make",
    "clean": "rimraf out dist node_modules package-lock.json"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.7.0",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.1",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bonjour": "^3.5.1",
    "bonjour-service": "^1.3.0",
    "express": "^5.2.1",
    "osc": "^2.4.5",
    "screenshot-desktop": "^1.15.3",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true
      },
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        }
      ],
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "OpenShockSpicer"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "linux"
          ]
        }
      ]
    }
  }
}
