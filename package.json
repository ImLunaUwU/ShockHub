{
  "name": "shockhub",
  "productName": "ShockHub",
  "version": "0.1.3",
  "description": "ShockHub desktop controller",
  "main": "main.js",
  "author": "Luna",
  "license": "MIT",
  "scripts": {
    "start": "electron-forge start",
    "dev": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32",
    "make:linux": "electron-forge make --platform=linux",
    "make:mac": "electron-forge make --platform=darwin",
    "make-debug": "cross-env DEBUG=electron-forge:* electron-forge make",
    "clean": "rimraf out dist node_modules package-lock.json"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.7.0",
    "@electron-forge/maker-squirrel": "^7.7.0",
    "@electron-forge/maker-zip": "^7.7.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.7.0",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^3.7.1",
    "cross-env": "^7.0.3",
    "electron": "^34.3.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "bonjour": "^3.5.1",
    "electron-squirrel-startup": "^1.0.1",
    "express": "^5.2.1",
    "osc": "^2.4.5",
    "ws": "^8.19.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "icon": "assets/icon.ico",
        "ignore": [
          "^/config\\.json$",
          "^/actions\\.log$"
        ]
      },
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        }
      ],
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "ShockHub",
            "loadingGif": "assets/installer-loading.gif",
            "setupIcon": "assets/icon.ico"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin",
            "linux"
          ]
        }
      ]
    }
  }
}
